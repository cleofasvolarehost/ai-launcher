            --model)             shift
                                 [[ $# -gt 0 ]] && CLAUDE_FLAGS+=("--model" "$1") && shift ;;
            --effort)            shift
                                 [[ $# -gt 0 ]] && CLAUDE_FLAGS+=("--effort" "$1") && shift ;;
            --add-dir)           shift
                                 [[ $# -gt 0 ]] && CLAUDE_FLAGS+=("--add-dir" "$1") && shift ;;
            --bare)              CLAUDE_FLAGS+=("--bare"); shift ;;
            *)                   break ;;
        esac
    done
    # Configura provider alternativo se --via foi passado
    if [[ -n "$_active_provider" ]]; then
        provider_setup_env "$_active_provider" || exit 1
        # Seta modelo default do provider se --model não foi explicitado
        _has_model=false
        for f in "${CLAUDE_FLAGS[@]}"; do
            [[ "$f" == "--model" ]] && _has_model=true && break
        done
        if [[ "$_has_model" == false ]]; then
            local_model="${PROVIDER_MODELS[$_active_provider]:-}"
            [[ -n "$local_model" ]] && CLAUDE_FLAGS+=("--model" "$local_model")
        fi
    fi
    enter_repo_if_needed
    launch "Claude Code" claude "$CLAUDE_PROMPT_FLAG" CLAUDE_FLAGS "$@"
