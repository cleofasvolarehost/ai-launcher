        shift
        declare -a _extra_flags=()
        read -ra _extra_flags <<< "$profile_flags"
        CLAUDE_FLAGS+=("${_extra_flags[@]}")
    fi
    # Extrai -w, --via, --no-status antes de processar outras flags
    parse_global_flags "$@"
    set -- "${_REMAINING_ARGS[@]+"${_REMAINING_ARGS[@]}"}"
    # Flags passthrough do Claude
    while [[ $# -gt 0 && ${1:-} == -* ]]; do
        case "$1" in
            -c|--continue)       CLAUDE_FLAGS+=("--continue"); _is_continuing=true; shift ;;
            -r|--resume)         CLAUDE_FLAGS+=("--resume"); _is_continuing=true; shift
