# Env vars extras por provider (timeout, tráfego, etc.)
declare -A PROVIDER_EXTRA_ENV=(
    [anthropic]=""
    [openrouter]=""
    [deepseek]="CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1 API_TIMEOUT_MS=600000"
    [ollama]="CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1 API_TIMEOUT_MS=600000"
    [lmstudio]="CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1 API_TIMEOUT_MS=600000"
    [litellm]="CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1"
)

_validate_provider_name() {
    [[ "$1" =~ ^[a-z0-9_-]+$ ]]
}

provider_load_key() {
    local provider="$1"
    _validate_provider_name "$provider" || return 1
    if [[ -f "$PROVIDERS_FILE" ]]; then
        grep -F "${provider}=" "$PROVIDERS_FILE" 2>/dev/null | grep "^${provider}=" | cut -d= -f2-
    fi
}

provider_save_key() {
    local provider="$1" key="$2"
    _validate_provider_name "$provider" || { echo -e "${RED}Nome de provider inválido.${RESET}"; return 1; }
    # Garante arquivo com permissões restritivas antes de escrever
    if [[ ! -f "$PROVIDERS_FILE" ]]; then
        install -m 600 /dev/null "$PROVIDERS_FILE"
    fi
    # Remove linha antiga usando grep para evitar injection no sed
    local tmpfile
    tmpfile=$(mktemp)
    trap "rm -f '$tmpfile'" RETURN
    grep -v "^${provider}=" "$PROVIDERS_FILE" > "$tmpfile" 2>/dev/null || true
    echo "${provider}=${key}" >> "$tmpfile"
    mv "$tmpfile" "$PROVIDERS_FILE"
    chmod 600 "$PROVIDERS_FILE"
    trap - RETURN
}

provider_setup_env() {
    local provider="$1"
    if [[ "$provider" == "anthropic" || -z "$provider" ]]; then
        return
    fi

    local base_url="${PROVIDER_URLS[$provider]:-}"
    if [[ -z "$base_url" ]]; then
        echo -e "${RED}Provider desconhecido: ${provider}${RESET}"
        return 1
    fi

    local api_key
    api_key=$(provider_load_key "$provider") || true

    # Providers locais não precisam de key real
    case "$provider" in
        ollama|lmstudio|litellm)
            api_key="${api_key:-${provider}}"
            ;;
        *)
            if [[ -z "$api_key" ]]; then
                if [[ -t 0 ]]; then
                    read -rsp "$(echo -e "  ${BOLD}API Key para ${provider}:${RESET} ")" api_key
                    echo ""
                    if [[ -n "$api_key" ]]; then
                        provider_save_key "$provider" "$api_key"
                        echo -e "${GREEN}✔ Key salva em ${PROVIDERS_FILE}${RESET}"
                    fi
                else
                    echo -e "${RED}Erro: API key para ${provider} não configurada.${RESET}"
                    echo "  Configure: ai p add ${provider}"
                    return 1
                fi
            fi
            ;;
    esac

    # Configura env vars conforme padrão do Claude Code
    # AUTH_TOKEN é o padrão para providers terceiros (não API_KEY)
    export ANTHROPIC_BASE_URL="$base_url"
    unset ANTHROPIC_API_KEY 2>/dev/null || true

    case "$provider" in
        openrouter)
            export OPENROUTER_API_KEY="$api_key"
            export ANTHROPIC_AUTH_TOKEN="$api_key"
            ;;
        *)
            export ANTHROPIC_AUTH_TOKEN="$api_key"
            ;;
    esac

    # Seta env vars extras do provider (timeout, disable traffic, etc.)
    local extras="${PROVIDER_EXTRA_ENV[$provider]:-}"
    if [[ -n "$extras" ]]; then
        local -a extra_pairs
        read -ra extra_pairs <<< "$extras"
        local pair key val
        for pair in "${extra_pairs[@]}"; do
            key="${pair%%=*}"
            val="${pair#*=}"
            [[ "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || continue
            export "$key"="$val"
        done
    fi

    # Model env vars para forçar o modelo em todos os contextos
    local model="${PROVIDER_MODELS[$provider]:-}"
    if [[ -n "$model" ]]; then
        export ANTHROPIC_MODEL="$model"
    fi

    echo -e "${CYAN}Provider:${RESET} ${provider} → ${base_url}"
}

provider_list() {
    echo -e "${BOLD}${CYAN}"
    echo "  ┌──────────────────────────────────────────────────┐"
    echo "  │         🔌 Providers Configurados                 │"
    echo "  └──────────────────────────────────────────────────┘"
    echo -e "${RESET}"

    for p in "${!PROVIDER_URLS[@]}"; do
        local url="${PROVIDER_URLS[$p]}"
        local key_status
        if [[ "$p" == "anthropic" ]]; then
            key_status="${GREEN}OAuth/default${RESET}"
        elif [[ "$p" == "ollama" || "$p" == "lmstudio" || "$p" == "litellm" ]]; then
            key_status="${DIM}local (sem key)${RESET}"
        elif [[ -n "$(provider_load_key "$p")" ]]; then
            key_status="${GREEN}✔ key salva${RESET}"
        else
            key_status="${YELLOW}✗ sem key${RESET}"
        fi
        local model="${PROVIDER_MODELS[$p]:-}"
        printf "  %-12s %b  ${DIM}model: %s${RESET}\n" "$p" "$key_status" "${model:-default}"
    done
    echo ""
}

