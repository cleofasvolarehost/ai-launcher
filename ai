#!/usr/bin/env bash
# ai - Lançador rápido de CLIs de IA com flags pré-configuradas
# https://github.com/cleofasvolarehost/ai-launcher
#
# Uso: ai (interativo) | ai c/x/g (direto) | ai c "prompt aqui"

set -euo pipefail

AI_LAUNCHER_VERSION="1.1.2"

# ╔══════════════════════════════════════════════════════╗
# ║  CONFIGURE SUAS FLAGS AQUI                          ║
# ╚══════════════════════════════════════════════════════╝
CLAUDE_FLAGS=(--dangerously-skip-permissions)
CODEX_FLAGS=(--dangerously-bypass-approvals-and-sandbox)
GEMINI_FLAGS=(--yolo)

# Variáveis de ambiente para cada CLI
export CLAUDE_CODE_NO_FLICKER=1

# Flag de prompt para cada CLI (cada uma usa sintaxe diferente)
CLAUDE_PROMPT_FLAG="-p"
CODEX_PROMPT_FLAG="-p"
GEMINI_PROMPT_FLAG="-p"

# Perfis do Claude (flags extras por modo)
get_claude_profile_flags() {
    case "$1" in
        fast)   echo "--model sonnet --effort low" ;;
        full)   echo "--model opus --effort max" ;;
        plan)   echo "--model opus --permission-mode plan" ;;
        sonnet) echo "--model sonnet" ;;
        opus)   echo "--model opus" ;;
        *)      return 1 ;;
    esac
}

# Diretório base para worktrees
WORKTREE_BASE="${HOME}/.worktrees"

# Arquivo de histórico
HISTORY_FILE="${HOME}/.local/share/ai-launcher/history"
mkdir -p "$(dirname "$HISTORY_FILE")"

# ── Cores (desativa se não for terminal) ─────────────────

if [[ -t 1 ]]; then
    BOLD='\033[1m'
    CYAN='\033[36m'
    GREEN='\033[32m'
    YELLOW='\033[33m'
    RED='\033[31m'
    DIM='\033[2m'
    RESET='\033[0m'
else
    BOLD='' CYAN='' GREEN='' YELLOW='' RED='' DIM='' RESET=''
fi

# ── Funções utilitárias ──────────────────────────────────

get_version() {
    local cmd="$1"
    if command -v "$cmd" &>/dev/null; then
        "$cmd" --version 2>/dev/null | head -1 || echo "?"
    else
        echo "-"
    fi
}

check_installed() {
    command -v "$1" &>/dev/null
}

status_icon() {
    local cmd="$1"
    if ! check_installed "$cmd"; then
        echo -e "${RED}✗ não instalado${RESET}"
    else
        echo -e "${GREEN}✔${RESET}"
    fi
}

save_history() {
    echo "$(date '+%Y-%m-%d %H:%M') | $1" >> "$HISTORY_FILE"
}

show_last_used() {
    if [[ -f "$HISTORY_FILE" ]]; then
        local last
        last=$(tail -1 "$HISTORY_FILE")
        echo -e "  ${DIM}Último uso: ${last}${RESET}"
    fi
}

normalize_choice() {
    printf '%s' "${1:-}" | tr -d '[:space:]'
}

launch() {
    local name="$1" cmd="$2" prompt_flag="$3"
    local flags_name="$4"
    shift 4

    local flags_ref=()
    case "$flags_name" in
        CLAUDE_FLAGS) flags_ref=("${CLAUDE_FLAGS[@]}") ;;
        CODEX_FLAGS)  flags_ref=("${CODEX_FLAGS[@]}") ;;
        GEMINI_FLAGS) flags_ref=("${GEMINI_FLAGS[@]}") ;;
        *)
            echo -e "${RED}Erro interno: array de flags desconhecida (${flags_name}).${RESET}"
            exit 1
            ;;
    esac

    if ! check_installed "$cmd"; then
        echo -e "${RED}Erro: ${cmd} não está instalado.${RESET}"
        case "$cmd" in
            claude) echo "  Instale: npm install -g @anthropic-ai/claude-code" ;;
            codex)  echo "  Instale: npm install -g @openai/codex" ;;
            gemini) echo "  Instale: sudo npm install -g @google/gemini-cli" ;;
        esac
        exit 1
    fi

    save_history "$name"

    if [[ $# -gt 0 ]]; then
        local prompt="$*"
        echo -e "${GREEN}Iniciando ${name}:${RESET} ${cmd} ${flags_ref[*]} ${prompt_flag} \"${prompt}\""
        echo ""
        exec "$cmd" "${flags_ref[@]}" "$prompt_flag" "$prompt"
    else
        echo -e "${GREEN}Iniciando ${name}:${RESET} ${cmd} ${flags_ref[*]}"
        echo ""
        exec "$cmd" "${flags_ref[@]}"
    fi
}

# ── Nomes aleatórios BR ────────────────────────────────

