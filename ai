# Extrai -w [nome] e --via [provider] e --no-status dos argumentos.
_use_worktree=true   # Worktree por padrão — use --no-wt para desabilitar
_wt_arg_name=""
_active_provider=""
_is_continuing=false
declare -a _REMAINING_ARGS=()

parse_global_flags() {
    local new_args=()
    _use_worktree=true
    _wt_arg_name=""
    _active_provider=""
    _is_continuing=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -w|--worktree)
                _use_worktree=true; shift
                if [[ $# -gt 0 && "${1:0:1}" != "-" ]]; then
                    _wt_arg_name="$1"; shift
                fi
                ;;
            --no-wt|--no-worktree)
                _use_worktree=false; _wt_arg_name=""; shift
                ;;
            --via)
                shift
                if [[ $# -gt 0 ]]; then
                    _active_provider="$1"; shift
                fi
                ;;
            *) new_args+=("$1"); shift ;;
        esac
    done
    _REMAINING_ARGS=("${new_args[@]+"${new_args[@]}"}")
}

# ── Flag toggle interativo ──────────────────────────────

CLAUDE_FLAGS_FILE="${HOME}/.local/share/ai-launcher/claude-flags.conf"

flags_menu() {
    echo -e "${BOLD}${CYAN}"
    echo "  ┌──────────────────────────────────────────────────┐"
    echo "  │         ⚙️  Toggle de Flags                       │"
    echo "  └──────────────────────────────────────────────────┘"
    echo -e "${RESET}"

    # Flags disponíveis para toggle
    local -a all_flags=(
        "--dangerously-skip-permissions"
        "--model sonnet"
        "--model opus"
        "--effort low"
        "--effort max"
        "--bare"
        "--continue"
        "--verbose"
    )
    local -a descriptions=(
        "Pular confirmações de permissão"
        "Usar modelo Sonnet"
        "Usar modelo Opus"
        "Effort mínimo (rápido)"
        "Effort máximo (completo)"
        "Modo bare (sem hooks/plugins)"
        "Continuar última conversa"
        "Modo verboso"
    )

    local changed=true
    while $changed; do
        changed=false
        echo -e "  ${BOLD}Flags atuais:${RESET} ${CLAUDE_FLAGS[*]+"${CLAUDE_FLAGS[*]}"}"
        echo ""

        for i in "${!all_flags[@]}"; do
            local flag="${all_flags[$i]}"
            local desc="${descriptions[$i]}"
            local status="${RED}OFF${RESET}"

            # Checa se a flag está ativa
            local -a flag_words; read -ra flag_words <<< "$flag"
            local is_active=false
            if [[ ${#flag_words[@]} -eq 1 ]]; then
                for f in "${CLAUDE_FLAGS[@]}"; do
                    [[ "$f" == "$flag" ]] && is_active=true && break
                done
            else
                # Flag com valor (--model sonnet)
                local found_key=false
                for j in "${!CLAUDE_FLAGS[@]}"; do
                    if [[ "${CLAUDE_FLAGS[$j]}" == "${flag_words[0]}" ]]; then
                        local next=$((j + 1))
                        if [[ $next -lt ${#CLAUDE_FLAGS[@]} && "${CLAUDE_FLAGS[$next]}" == "${flag_words[1]}" ]]; then
                            is_active=true
                            break
                        fi
                    fi
                done
            fi

            [[ "$is_active" == true ]] && status="${GREEN}ON ${RESET}"
            printf "  ${BOLD}%d)${RESET} [%b] %-35s %s\n" "$((i + 1))" "$status" "$flag" "$desc"
        done

        echo ""
        echo -e "  ${DIM}0) Pronto — lançar com estas flags${RESET}"
        echo ""
        read -rp "Toggle [1-${#all_flags[@]}/0]: " choice

        [[ "$choice" == "0" || -z "$choice" ]] && break

        if [[ "$choice" -ge 1 && "$choice" -le ${#all_flags[@]} ]] 2>/dev/null; then
            changed=true
            local idx=$((choice - 1))
            local flag="${all_flags[$idx]}"
            local -a flag_words; read -ra flag_words <<< "$flag"

            if [[ ${#flag_words[@]} -eq 1 ]]; then
                # Toggle flag simples
                local new_flags=()
                local removed=false
                for f in "${CLAUDE_FLAGS[@]}"; do
                    if [[ "$f" == "$flag" && "$removed" == false ]]; then
                        removed=true
                    else
                        new_flags+=("$f")
                    fi
                done
                if [[ "$removed" == false ]]; then
                    new_flags+=("$flag")
                fi
                CLAUDE_FLAGS=("${new_flags[@]+"${new_flags[@]}"}")
            else
                # Toggle flag com valor — remove se existe, adiciona se não
                local new_flags=()
                local removed=false
                local skip_next=false
                for j in "${!CLAUDE_FLAGS[@]}"; do
                    if $skip_next; then skip_next=false; continue; fi
                    if [[ "${CLAUDE_FLAGS[$j]}" == "${flag_words[0]}" ]]; then
                        local next=$((j + 1))
                        if [[ $next -lt ${#CLAUDE_FLAGS[@]} && "${CLAUDE_FLAGS[$next]}" == "${flag_words[1]}" ]]; then
                            removed=true
                            skip_next=true
                            continue
                        fi
                    fi
                    new_flags+=("${CLAUDE_FLAGS[$j]}")
                done
                if [[ "$removed" == false ]]; then
                    # Remove outras opções do mesmo grupo (--model, --effort)
                    local group_key="${flag_words[0]}"
                    local clean_flags=()
                    skip_next=false
                    for j in "${!new_flags[@]}"; do
                        if $skip_next; then skip_next=false; continue; fi
                        if [[ "${new_flags[$j]}" == "$group_key" ]]; then
                            skip_next=true
                            continue
                        fi
                        clean_flags+=("${new_flags[$j]}")
                    done
                    clean_flags+=("${flag_words[@]}")
                    new_flags=("${clean_flags[@]}")
                fi
                CLAUDE_FLAGS=("${new_flags[@]+"${new_flags[@]}"}")
            fi
            echo ""
        fi
    done

    echo -e "${GREEN}Flags finais:${RESET} ${CLAUDE_FLAGS[*]+"${CLAUDE_FLAGS[*]}"}"
    echo ""
}

# ── Repos conhecidos: picker inteligente ────────────────

# Resolve o repo principal (mesmo se estivermos dentro de um worktree)
repo_resolve_main() {
    git worktree list --porcelain 2>/dev/null | awk '/^worktree / {print $2; exit}'
}

# Registra 1+ repos no topo do arquivo (LRU). Variádico — aceita múltiplos paths.
# Usa mkdir como lock atômico (portável Linux+macOS) e awk pra dedup preservando ordem.
repo_register() {
    local -a new_repos=()
    local r
    for r in "$@"; do
        [[ -n "$r" && -d "$r" && -d "$r/.git" ]] && new_repos+=("$r")
    done
    (( ${#new_repos[@]} == 0 )) && return

    # Lock atômico: tenta até 5 vezes, desiste silencioso (pior caso: perde 1 write)
    local lock="${REPOS_FILE}.lock"
    local tries=0
    while ! mkdir "$lock" 2>/dev/null; do
        tries=$((tries + 1))
        (( tries >= 5 )) && break
        sleep 0.1
    done

    if [[ ! -f "$REPOS_FILE" ]]; then
        install -m 600 /dev/null "$REPOS_FILE"
    fi

    local tmp
    tmp=$(mktemp)
    trap "rm -f '$tmp'; rmdir '$lock' 2>/dev/null || true" RETURN

    {
        printf '%s\n' "${new_repos[@]}"
        cat "$REPOS_FILE" 2>/dev/null || true
    } | awk 'NF && !seen[$0]++' | head -30 > "$tmp"

    mv "$tmp" "$REPOS_FILE"
    chmod 600 "$REPOS_FILE"
}

# Registra o repo atual (chamado automaticamente quando ai é lançado dentro de um)
repo_register_current() {
    local main_root
    main_root=$(repo_resolve_main)
    [[ -n "$main_root" ]] && repo_register "$main_root"
}

# Escaneia locais comuns em busca de repos git (ignora caches/ferramentas)
repo_scan() {
    local -a locations=(
        "$HOME"
        "$HOME/Documentos" "$HOME/Documents"
        "$HOME/projects" "$HOME/Projects"
        "$HOME/dev" "$HOME/Dev"
        "$HOME/code" "$HOME/Code"
        "$HOME/workspace" "$HOME/Workspace"
        "$HOME/repos" "$HOME/src" "$HOME/git"
    )
    local loc depth
    for loc in "${locations[@]}"; do
        [[ -d "$loc" ]] || continue
        # Raso no $HOME (só projetos de primeiro nível), mais fundo em subdirs dedicados
        if [[ "$loc" == "$HOME" ]]; then depth=2; else depth=4; fi
        find "$loc" -maxdepth "$depth" -name ".git" -type d \
            -not -path "*/node_modules/*" \
            -not -path "*/.worktrees/*" \
            -not -path "*/vendor/*" \
            -not -path "*/.cache/*" \
            -not -path "*/.codex/*" \
            -not -path "*/.claude/*" \
            -not -path "*/.config/*" \
            -not -path "*/.local/*" \
            -not -path "*/.vscode/*" \
            -not -path "*/.npm/*" \
            -not -path "*/Library/*" \
            -print 2>/dev/null | while read -r git_dir; do
            dirname "$git_dir"
        done
    done | sort -u
}

# Lista repos conhecidos (ordem: mais recente primeiro)
repo_list_known() {
    [[ -f "$REPOS_FILE" ]] && cat "$REPOS_FILE"
}

# Trunca nome longo com reticências preservando alinhamento
_repo_display_name() {
    local name="$1"
    if (( ${#name} > 22 )); then
        echo "${name:0:19}..."
    else
        echo "$name"
    fi
}

# Picker interativo. Dá cd no repo escolhido. Retorna 0 em sucesso.
# Loop até o usuário escolher/cancelar (evita recursão empilhada em 's').
repo_pick() {
    [[ ! -t 0 ]] && return 1

    local -a repos=()
    local line
    local first_run=true

    while true; do
        # (Re)carrega a lista a cada iteração para refletir scans
        repos=()
        while IFS= read -r line; do
            [[ -n "$line" && -d "$line" && -d "$line/.git" ]] && repos+=("$line")
        done < <(repo_list_known)

        # Auto-scan só na primeira iteração, se a lista estiver vazia
        if [[ ${#repos[@]} -eq 0 && "$first_run" == true ]]; then
            first_run=false
            echo -e "${DIM}Primeira vez — escaneando seus projetos em ${HOME}...${RESET}"
            local -a scanned=()
            while IFS= read -r line; do
                scanned+=("$line")
            done < <(repo_scan)
            if (( ${#scanned[@]} > 0 )); then
                repo_register "${scanned[@]}"
                repos=("${scanned[@]}")
            fi
        fi
        first_run=false

        if [[ ${#repos[@]} -eq 0 ]]; then
            echo -e "${RED}Nenhum repo git encontrado em ${HOME}.${RESET}"
            echo -e "${DIM}Navegue até um repo antes (cd /seu/projeto) ou use --no-wt.${RESET}"
            return 1
        fi

        echo -e "${BOLD}${CYAN}📦 Escolha o projeto:${RESET}"
        echo ""
        local i
        for i in "${!repos[@]}"; do
            local repo="${repos[$i]}"
            local name branch
            name=$(_repo_display_name "$(basename "$repo")")
            branch=$(git -C "$repo" symbolic-ref --short HEAD 2>/dev/null || echo "?")
            printf "  ${BOLD}%2d)${RESET} %-22s ${DIM}[%s] %s${RESET}\n" "$((i+1))" "$name" "$branch" "$repo"
        done
        echo ""
        echo -e "  ${DIM} s) Escanear ${HOME} por mais repos${RESET}"
        echo -e "  ${DIM} 0) Cancelar (abrir sem worktree)${RESET}"
        echo ""

        local choice
        read -rp "Escolha [1-${#repos[@]}/s/0]: " choice
        choice=$(normalize_choice "$choice")

        case "$choice" in
            s|S)
                echo -e "${DIM}Escaneando...${RESET}"
                local -a scanned=()
                while IFS= read -r line; do
                    scanned+=("$line")
                done < <(repo_scan)
                if (( ${#scanned[@]} > 0 )); then
                    repo_register "${scanned[@]}"
                fi
                echo -e "${GREEN}✔ ${#scanned[@]} repo(s) indexados.${RESET}"
                echo ""
                continue
                ;;
            0|"")
                return 1
                ;;
        esac

        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#repos[@]} )); then
            local picked="${repos[$((choice-1))]}"
            if ! cd "$picked"; then
                echo -e "${RED}Erro ao entrar em ${picked}.${RESET}"
                return 1
            fi
            repo_register "$picked"
            echo -e "${GREEN}→ ${picked}${RESET}"
            return 0
        fi

        echo -e "${RED}Opção inválida.${RESET}"
        echo ""
    done
}

enter_worktree_if_needed() {
    local cli_name="$1"
    # Reset estado de worktrees anteriores
    _WT_CREATED_NAME=""
    _WT_DIR=""
    # Pula worktree se --continue/--resume (volta à sessão existente)
    if [[ "$_is_continuing" == true ]]; then
        return
    fi
    if [[ "$_use_worktree" == true ]]; then
        if ! git rev-parse --is-inside-work-tree &>/dev/null; then
            # Não estamos num repo git — oferece seletor de projetos se interativo
            if [[ -t 0 ]]; then
                echo -e "${YELLOW}Você não está dentro de um repo git.${RESET}"
                if ! repo_pick; then
                    echo -e "${DIM}(continuando sem worktree)${RESET}"
                    return
                fi
            else
                echo -e "${DIM}(sem repo git — worktree pulado; use 'cd /seu/projeto' antes)${RESET}"
                return
            fi
        else
            # Registra o repo atual para o picker lembrar em futuras invocações
            repo_register_current
        fi
        if wt_prepare "$_wt_arg_name" && [[ -n "$_WT_DIR" && -d "$_WT_DIR" ]]; then
            echo -e "${GREEN}Worktree:${RESET} ${_WT_CREATED_NAME} → ${_WT_DIR}"
            cd "$_WT_DIR"
        else
            echo -e "${RED}Erro ao preparar worktree. Abrindo ${cli_name} no diretório atual.${RESET}"
        fi
    fi
}

if [[ ${1:-} == "claude" || ${1:-} == "c" ]]; then
    shift
    # Verifica se o primeiro arg é um perfil
    profile_name="${1:-}"
    if profile_flags=$(get_claude_profile_flags "$profile_name" 2>/dev/null); then
        shift
        declare -a _extra_flags=()
        read -ra _extra_flags <<< "$profile_flags"
        CLAUDE_FLAGS+=("${_extra_flags[@]}")
    fi
    # Extrai -w, --via, --no-status antes de processar outras flags
    parse_global_flags "$@"
    set -- "${_REMAINING_ARGS[@]+"${_REMAINING_ARGS[@]}"}"
    # Flags passthrough do Claude
    while [[ $# -gt 0 && ${1:-} == -* ]]; do
        case "$1" in
            -c|--continue)       CLAUDE_FLAGS+=("--continue"); _is_continuing=true; shift ;;
            -r|--resume)         CLAUDE_FLAGS+=("--resume"); _is_continuing=true; shift
                                 [[ $# -gt 0 && "${1:0:1}" != "-" ]] && CLAUDE_FLAGS+=("$1") && shift ;;
            -n|--name)           shift
                                 [[ $# -gt 0 ]] && CLAUDE_FLAGS+=("--name" "$1") && shift ;;
            --model)             shift
                                 [[ $# -gt 0 ]] && CLAUDE_FLAGS+=("--model" "$1") && shift ;;
            --effort)            shift
                                 [[ $# -gt 0 ]] && CLAUDE_FLAGS+=("--effort" "$1") && shift ;;
            --add-dir)           shift
                                 [[ $# -gt 0 ]] && CLAUDE_FLAGS+=("--add-dir" "$1") && shift ;;
            --bare)              CLAUDE_FLAGS+=("--bare"); shift ;;
            *)                   break ;;
        esac
    done
    # Configura provider alternativo se --via foi passado
    if [[ -n "$_active_provider" ]]; then
        provider_setup_env "$_active_provider" || exit 1
        # Seta modelo default do provider se --model não foi explicitado
        _has_model=false
        for f in "${CLAUDE_FLAGS[@]}"; do
            [[ "$f" == "--model" ]] && _has_model=true && break
        done
        if [[ "$_has_model" == false ]]; then
            local_model="${PROVIDER_MODELS[$_active_provider]:-}"
            [[ -n "$local_model" ]] && CLAUDE_FLAGS+=("--model" "$local_model")
        fi
    fi
    enter_worktree_if_needed "Claude"
    # Auto-nomeia sessão com o worktree, se -n não foi passado manualmente
    if [[ "$_use_worktree" == true && -n "$_WT_CREATED_NAME" ]]; then
        _has_name=false
        for f in "${CLAUDE_FLAGS[@]}"; do
            [[ "$f" == "--name" ]] && _has_name=true && break
        done
        [[ "$_has_name" == false ]] && CLAUDE_FLAGS+=("--name" "$_WT_CREATED_NAME")
    fi
    launch "Claude Code" claude "$CLAUDE_PROMPT_FLAG" CLAUDE_FLAGS "$@"
elif [[ ${1:-} == "codex" || ${1:-} == "x" ]]; then
    shift
    parse_global_flags "$@"
    set -- "${_REMAINING_ARGS[@]+"${_REMAINING_ARGS[@]}"}"
    enter_worktree_if_needed "Codex"
    launch "Codex" codex "$CODEX_PROMPT_FLAG" CODEX_FLAGS "$@"
elif [[ ${1:-} == "gemini" || ${1:-} == "g" ]]; then
    shift
    parse_global_flags "$@"
    set -- "${_REMAINING_ARGS[@]+"${_REMAINING_ARGS[@]}"}"
    enter_worktree_if_needed "Gemini"
    launch "Gemini" gemini "$GEMINI_PROMPT_FLAG" GEMINI_FLAGS "$@"
elif [[ ${1:-} == "provider" || ${1:-} == "p" ]]; then
    shift
    subcmd="${1:-}"
    [[ -n "$subcmd" ]] && shift
    case "$subcmd" in
        ls|list) provider_list ;;
        add)
            pname="${1:-}"
            pkey="${2:-}"
            if [[ -z "$pname" ]]; then
                echo -e "${RED}Uso: ai p add <provider> [api-key]${RESET}"
                echo "  Providers: ${!PROVIDER_URLS[*]}"
                exit 1
            fi
            if [[ -z "${PROVIDER_URLS[$pname]+x}" ]]; then
                echo -e "${RED}Provider desconhecido: ${pname}${RESET}"
                echo "  Disponíveis: ${!PROVIDER_URLS[*]}"
                exit 1
            fi
            if [[ -z "$pkey" && -t 0 ]]; then
                read -rsp "$(echo -e "  ${BOLD}API Key para ${pname}:${RESET} ")" pkey
                echo ""
            fi
            if [[ -n "$pkey" ]]; then
                provider_save_key "$pname" "$pkey"
                echo -e "${GREEN}✔ Key salva para ${pname}${RESET}"
            else
                echo -e "${RED}Erro: key vazia.${RESET}"
                exit 1
            fi
            ;;
        del|rm)
            pname="${1:-}"
            if [[ -z "$pname" ]]; then
                echo -e "${RED}Uso: ai p del <provider>${RESET}"
                exit 1
            fi
            _validate_provider_name "$pname" || { echo -e "${RED}Nome inválido.${RESET}"; exit 1; }
            if [[ -f "$PROVIDERS_FILE" ]]; then
                _tmpfile=$(mktemp)
                trap "rm -f '$_tmpfile'" EXIT
                grep -v "^${pname}=" "$PROVIDERS_FILE" > "$_tmpfile" 2>/dev/null || true
                mv "$_tmpfile" "$PROVIDERS_FILE"
                chmod 600 "$PROVIDERS_FILE"
                trap - EXIT
                echo -e "${GREEN}✔ Key removida para ${pname}${RESET}"
            fi
            ;;
        "")
            provider_list
            ;;
        *)
            echo -e "${RED}Subcomando desconhecido: ${subcmd}${RESET}"
            echo "Use: ai p ls|add|del"
            exit 1
            ;;
    esac
    exit 0
elif [[ ${1:-} == "flags" || ${1:-} == "f" ]]; then
    shift
    if [[ ! -t 0 ]]; then
        echo -e "${RED}Erro: toggle de flags requer terminal interativo.${RESET}"
        exit 1
    fi
    flags_menu
    # Após toggle, lança Claude com as flags escolhidas
    launch "Claude Code" claude "$CLAUDE_PROMPT_FLAG" CLAUDE_FLAGS "$@"
elif [[ ${1:-} == "w" || ${1:-} == "wt" ]]; then
    shift
    subcmd="${1:-}"
    [[ -n "$subcmd" ]] && shift
    case "$subcmd" in
        new)   wt_new "${1:-}" ;;
        ls)    wt_list ;;
        del)   wt_delete "${1:-}" ;;
        clean) wt_clean ;;
        open)  wt_open "${1:-}" ;;
        "")    wt_menu ;;
        *)     echo -e "${RED}Subcomando desconhecido: ${subcmd}${RESET}"
               echo "Use: ai w new|ls|del|clean|open"
               exit 1 ;;
    esac
    exit 0
elif [[ ${1:-} == "repo" || ${1:-} == "repos" || ${1:-} == "r" ]]; then
    shift
    subcmd="${1:-}"
    [[ -n "$subcmd" ]] && shift
    case "$subcmd" in
        ls|list|"")
            echo -e "${BOLD}${CYAN}📦 Repos conhecidos${RESET} ${DIM}(mais recente primeiro)${RESET}"
            echo ""
            n=0
            while IFS= read -r line; do
                [[ -z "$line" ]] && continue
                n=$((n+1))
                display=$(_repo_display_name "$(basename "$line")")
                if [[ -d "$line/.git" ]]; then
                    branch=$(git -C "$line" symbolic-ref --short HEAD 2>/dev/null || echo "?")
                    printf "  ${GREEN}✔${RESET} %-22s ${DIM}[%s] %s${RESET}\n" "$display" "$branch" "$line"
                else
                    printf "  ${RED}✗${RESET} %-22s ${DIM}%s (sumiu)${RESET}\n" "$display" "$line"
                fi
            done < <(repo_list_known)
            [[ $n -eq 0 ]] && echo -e "  ${DIM}Nenhum — rode: ai r scan${RESET}"
            echo ""
            ;;
        scan)
            echo -e "${DIM}Escaneando ${HOME}...${RESET}"
            scanned=()
            while IFS= read -r line; do
                scanned+=("$line")
            done < <(repo_scan)
            if (( ${#scanned[@]} > 0 )); then
                repo_register "${scanned[@]}"
            fi
            echo -e "${GREEN}✔ ${#scanned[@]} repo(s) indexados em ${REPOS_FILE}${RESET}"
            ;;
        add)
            _add_path="${1:-$PWD}"
            _add_path=$(cd "$_add_path" 2>/dev/null && pwd) || {
                echo -e "${RED}Path inválido: ${1:-$PWD}${RESET}"; exit 1;
            }
            if [[ ! -d "$_add_path/.git" ]]; then
                echo -e "${RED}Não é um repo git: ${_add_path}${RESET}"; exit 1;
            fi
            repo_register "$_add_path"
            echo -e "${GREEN}✔ Registrado: ${_add_path}${RESET}"
            ;;
        forget|rm|del|clean)
            rm -f "$REPOS_FILE"
            echo -e "${GREEN}✔ Lista de repos esquecida.${RESET}"
            ;;
        pick)
            repo_pick || { echo -e "${DIM}cancelado${RESET}"; exit 1; }
            echo -e "${GREEN}Dica:${RESET} rode ${BOLD}ai c${RESET} agora para criar worktree aqui."
            ;;
        *)
            echo -e "${RED}Subcomando desconhecido: ${subcmd}${RESET}"
            echo "Use: ai r ls|scan|add [path]|pick|forget"
            exit 1
            ;;
    esac
    exit 0
elif [[ -n ${1:-} ]]; then
    echo "Opção desconhecida: $1"
    echo "Use: ai --help"
    exit 1
fi

# ── Menu interativo ──────────────────────────────────────

if [[ ! -t 0 ]]; then
    echo -e "${RED}Erro: menu interativo requer terminal.${RESET}"
    echo "Use: ai c | ai x | ai g | ai --help"
    exit 1
fi

claude_status=$(status_icon claude)
codex_status=$(status_icon codex)
gemini_status=$(status_icon gemini)

claude_ver=$(get_version claude)
codex_ver=$(get_version codex)
gemini_ver=$(get_version gemini)

echo -e "${BOLD}${CYAN}"
echo "  ┌──────────────────────────────────────────────────┐"
echo "  │         AI CLI Launcher v${AI_LAUNCHER_VERSION}                    │"
echo "  └──────────────────────────────────────────────────┘"
echo -e "${RESET}"

printf "  ${BOLD}1)${RESET} Claude Code  %-20s %b\n" "${claude_ver}" "${claude_status}"
printf "  ${BOLD}2)${RESET} Codex        %-20s %b\n" "${codex_ver}" "${codex_status}"
printf "  ${BOLD}3)${RESET} Gemini       %-20s %b\n" "${gemini_ver}" "${gemini_status}"
echo ""
echo -e "  ${BOLD}4)${RESET} 🌳 Worktree Manager"
echo -e "  ${BOLD}5)${RESET} 🔌 Providers"
echo -e "  ${BOLD}6)${RESET} ⚙️  Toggle Flags"
echo -e "  ${DIM}0) Sair${RESET}"
echo ""

echo -e "${YELLOW}Flags:${RESET}"
echo -e "  ${DIM}Claude: ${CLAUDE_FLAGS[*]+"${CLAUDE_FLAGS[*]}"}${RESET}"
echo -e "  ${DIM}Codex:  ${CODEX_FLAGS[*]+"${CODEX_FLAGS[*]}"}${RESET}"
echo -e "  ${DIM}Gemini: ${GEMINI_FLAGS[*]+"${GEMINI_FLAGS[*]}"}${RESET}"
echo ""

show_last_used
echo ""

read -rp "Escolha [1-6/0]: " choice
choice=$(normalize_choice "$choice")

case $choice in
    1) enter_worktree_if_needed "Claude"
       if [[ "$_use_worktree" == true && -n "${_WT_CREATED_NAME:-}" ]]; then
           _has_name=false
           for f in "${CLAUDE_FLAGS[@]}"; do
               [[ "$f" == "--name" ]] && _has_name=true && break
           done
           [[ "$_has_name" == false ]] && CLAUDE_FLAGS+=("--name" "$_WT_CREATED_NAME")
       fi
       launch "Claude Code" claude "$CLAUDE_PROMPT_FLAG" CLAUDE_FLAGS ;;
    2) enter_worktree_if_needed "Codex"
       launch "Codex" codex "$CODEX_PROMPT_FLAG" CODEX_FLAGS ;;
    3) enter_worktree_if_needed "Gemini"
       launch "Gemini" gemini "$GEMINI_PROMPT_FLAG" GEMINI_FLAGS ;;
    4) wt_menu ;;
    5) provider_list ;;
    6) flags_menu
       # Detecta --continue/--resume toggled via flags menu
       for _f in "${CLAUDE_FLAGS[@]}"; do
           [[ "$_f" == "--continue" || "$_f" == "--resume" ]] && _is_continuing=true
       done
       enter_worktree_if_needed "Claude"
       launch "Claude Code" claude "$CLAUDE_PROMPT_FLAG" CLAUDE_FLAGS ;;
    0) echo "Saindo."; exit 0 ;;
    *) echo "Opção inválida."; exit 1 ;;
esac
