# Extrai --via e outras flags globais antes de processar flags específicas.
_active_provider=""
_is_continuing=false
declare -a _REMAINING_ARGS=()

parse_global_flags() {
    local new_args=()
    _active_provider=""
    _is_continuing=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --via)
                shift
                if [[ $# -gt 0 ]]; then
                    _active_provider="$1"; shift
                fi
                ;;
            *) new_args+=("$1"); shift ;;
        esac
    done
    _REMAINING_ARGS=("${new_args[@]+"${new_args[@]}"}")
}

# ── Flag toggle interativo ──────────────────────────────

CLAUDE_FLAGS_FILE="${HOME}/.local/share/ai-launcher/claude-flags.conf"

flags_menu() {
    echo -e "${BOLD}${CYAN}"
    echo "  ┌──────────────────────────────────────────────────┐"
    echo "  │         ⚙️  Toggle de Flags                       │"
    echo "  └──────────────────────────────────────────────────┘"
    echo -e "${RESET}"

    # Flags disponíveis para toggle
    local -a all_flags=(
        "--dangerously-skip-permissions"
        "--model sonnet"
        "--model opus"
        "--effort low"
        "--effort max"
        "--bare"
        "--continue"
        "--verbose"
    )
    local -a descriptions=(
        "Pular confirmações de permissão"
        "Usar modelo Sonnet"
        "Usar modelo Opus"
        "Effort mínimo (rápido)"
        "Effort máximo (completo)"
        "Modo bare (sem hooks/plugins)"
        "Continuar última conversa"
        "Modo verboso"
    )

    local changed=true
    while $changed; do
        changed=false
        echo -e "  ${BOLD}Flags atuais:${RESET} ${CLAUDE_FLAGS[*]+"${CLAUDE_FLAGS[*]}"}"
        echo ""

        for i in "${!all_flags[@]}"; do
            local flag="${all_flags[$i]}"
            local desc="${descriptions[$i]}"
            local status="${RED}OFF${RESET}"

            # Checa se a flag está ativa
            local -a flag_words; read -ra flag_words <<< "$flag"
            local is_active=false
            if [[ ${#flag_words[@]} -eq 1 ]]; then
                for f in "${CLAUDE_FLAGS[@]}"; do
                    [[ "$f" == "$flag" ]] && is_active=true && break
                done
            else
                # Flag com valor (--model sonnet)
                local found_key=false
                for j in "${!CLAUDE_FLAGS[@]}"; do
                    if [[ "${CLAUDE_FLAGS[$j]}" == "${flag_words[0]}" ]]; then
                        local next=$((j + 1))
                        if [[ $next -lt ${#CLAUDE_FLAGS[@]} && "${CLAUDE_FLAGS[$next]}" == "${flag_words[1]}" ]]; then
                            is_active=true
                            break
                        fi
                    fi
                done
            fi

            [[ "$is_active" == true ]] && status="${GREEN}ON ${RESET}"
            printf "  ${BOLD}%d)${RESET} [%b] %-35s %s\n" "$((i + 1))" "$status" "$flag" "$desc"
        done

        echo ""
        echo -e "  ${DIM}0) Pronto — lançar com estas flags${RESET}"
        echo ""
        read -rp "Toggle [1-${#all_flags[@]}/0]: " choice

        [[ "$choice" == "0" || -z "$choice" ]] && break

        if [[ "$choice" -ge 1 && "$choice" -le ${#all_flags[@]} ]] 2>/dev/null; then
            changed=true
            local idx=$((choice - 1))
            local flag="${all_flags[$idx]}"
            local -a flag_words; read -ra flag_words <<< "$flag"

            if [[ ${#flag_words[@]} -eq 1 ]]; then
                # Toggle flag simples
                local new_flags=()
                local removed=false
                for f in "${CLAUDE_FLAGS[@]}"; do
                    if [[ "$f" == "$flag" && "$removed" == false ]]; then
                        removed=true
                    else
                        new_flags+=("$f")
                    fi
                done
                if [[ "$removed" == false ]]; then
                    new_flags+=("$flag")
                fi
                CLAUDE_FLAGS=("${new_flags[@]+"${new_flags[@]}"}")
            else
                # Toggle flag com valor — remove se existe, adiciona se não
                local new_flags=()
                local removed=false
                local skip_next=false
                for j in "${!CLAUDE_FLAGS[@]}"; do
                    if $skip_next; then skip_next=false; continue; fi
                    if [[ "${CLAUDE_FLAGS[$j]}" == "${flag_words[0]}" ]]; then
                        local next=$((j + 1))
                        if [[ $next -lt ${#CLAUDE_FLAGS[@]} && "${CLAUDE_FLAGS[$next]}" == "${flag_words[1]}" ]]; then
                            removed=true
                            skip_next=true
                            continue
                        fi
                    fi
                    new_flags+=("${CLAUDE_FLAGS[$j]}")
                done
                if [[ "$removed" == false ]]; then
                    # Remove outras opções do mesmo grupo (--model, --effort)
                    local group_key="${flag_words[0]}"
                    local clean_flags=()
                    skip_next=false
                    for j in "${!new_flags[@]}"; do
                        if $skip_next; then skip_next=false; continue; fi
                        if [[ "${new_flags[$j]}" == "$group_key" ]]; then
                            skip_next=true
                            continue
                        fi
                        clean_flags+=("${new_flags[$j]}")
                    done
                    clean_flags+=("${flag_words[@]}")
                    new_flags=("${clean_flags[@]}")
                fi
                CLAUDE_FLAGS=("${new_flags[@]+"${new_flags[@]}"}")
            fi
            echo ""
        fi
    done

    echo -e "${GREEN}Flags finais:${RESET} ${CLAUDE_FLAGS[*]+"${CLAUDE_FLAGS[*]}"}"
    echo ""
}

# ── Repos conhecidos: picker inteligente ────────────────

# Resolve o repo principal (mesmo se estivermos dentro de um worktree)
repo_resolve_main() {
    git worktree list --porcelain 2>/dev/null | awk '/^worktree / {print $2; exit}'
}

# Registra 1+ repos no topo do arquivo (LRU). Variádico — aceita múltiplos paths.
# Usa mkdir como lock atômico (portável Linux+macOS) e awk pra dedup preservando ordem.
repo_register() {
    local -a new_repos=()
    local r
    for r in "$@"; do
        [[ -n "$r" && -d "$r" && -d "$r/.git" ]] && new_repos+=("$r")
    done
    (( ${#new_repos[@]} == 0 )) && return

    # Lock atômico: tenta até 5 vezes, desiste silencioso (pior caso: perde 1 write)
    local lock="${REPOS_FILE}.lock"
    local tries=0
    while ! mkdir "$lock" 2>/dev/null; do
        tries=$((tries + 1))
        (( tries >= 5 )) && break
        sleep 0.1
    done

    if [[ ! -f "$REPOS_FILE" ]]; then
        install -m 600 /dev/null "$REPOS_FILE"
    fi

    local tmp
    tmp=$(mktemp)
    trap "rm -f '$tmp'; rmdir '$lock' 2>/dev/null || true" RETURN

    {
        printf '%s\n' "${new_repos[@]}"
        cat "$REPOS_FILE" 2>/dev/null || true
    } | awk 'NF && !seen[$0]++' | head -30 > "$tmp"

    mv "$tmp" "$REPOS_FILE"
    chmod 600 "$REPOS_FILE"
}

# Registra o repo atual (chamado automaticamente quando ai é lançado dentro de um)
repo_register_current() {
    local main_root
    main_root=$(repo_resolve_main)
    [[ -n "$main_root" ]] && repo_register "$main_root"
}

# Escaneia locais comuns em busca de repos git (ignora caches/ferramentas)
repo_scan() {
    local -a locations=(
        "$HOME"
        "$HOME/Documentos" "$HOME/Documents"
        "$HOME/projects" "$HOME/Projects"
        "$HOME/dev" "$HOME/Dev"
        "$HOME/code" "$HOME/Code"
        "$HOME/workspace" "$HOME/Workspace"
        "$HOME/repos" "$HOME/src" "$HOME/git"
        "$HOME/Desktop" "$HOME/Área de Trabalho" "$HOME/Ambiente de Trabalho"
        "$HOME/Apps" "$HOME/apps" "$HOME/sites" "$HOME/Sites"
        "$HOME/trabalho" "$HOME/Trabalho"
    )
    local loc depth
    for loc in "${locations[@]}"; do
        [[ -d "$loc" ]] || continue
        # Raso no $HOME (só projetos de primeiro nível), mais fundo em subdirs dedicados
        if [[ "$loc" == "$HOME" ]]; then depth=2; else depth=4; fi
        find "$loc" -maxdepth "$depth" -name ".git" -type d \
            -not -path "*/node_modules/*" \
            -not -path "*/.worktrees/*" \
            -not -path "*/vendor/*" \
            -not -path "*/.cache/*" \
            -not -path "*/.codex/*" \
            -not -path "*/.claude/*" \
            -not -path "*/.config/*" \
            -not -path "*/.local/*" \
            -not -path "*/.vscode/*" \
            -not -path "*/.npm/*" \
            -not -path "*/Library/*" \
            -print 2>/dev/null | while read -r git_dir; do
            dirname "$git_dir"
        done
    done | sort -u
}

# Lista repos conhecidos (ordem: mais recente primeiro)
repo_list_known() {
    [[ -f "$REPOS_FILE" ]] && cat "$REPOS_FILE"
}

# Trunca nome longo com reticências preservando alinhamento
_repo_display_name() {
    local name="$1"
    if (( ${#name} > 22 )); then
        echo "${name:0:19}..."
    else
        echo "$name"
    fi
}

# Picker interativo. Dá cd no repo escolhido. Retorna 0 em sucesso.
# Loop até o usuário escolher/cancelar (evita recursão empilhada em 's').
repo_pick() {
    [[ ! -t 0 ]] && return 1

    local -a repos=()
    local line
    local first_run=true

    while true; do
        # (Re)carrega a lista a cada iteração para refletir scans
        repos=()
        while IFS= read -r line; do
            [[ -n "$line" && -d "$line" && -d "$line/.git" ]] && repos+=("$line")
        done < <(repo_list_known)

        # Auto-scan só na primeira iteração, se a lista estiver vazia
        if [[ ${#repos[@]} -eq 0 && "$first_run" == true ]]; then
            first_run=false
            echo -e "${DIM}Primeira vez — escaneando seus projetos em ${HOME}...${RESET}"
            local -a scanned=()
            while IFS= read -r line; do
                scanned+=("$line")
            done < <(repo_scan)
            if (( ${#scanned[@]} > 0 )); then
                repo_register "${scanned[@]}"
                repos=("${scanned[@]}")
            fi
        fi
        first_run=false

        if [[ ${#repos[@]} -eq 0 ]]; then
            echo -e "${YELLOW}Nenhum repo git encontrado em ${HOME}.${RESET}"
            echo -e "${DIM}Locais verificados: \$HOME, Documentos, projects, dev, code, workspace, Desktop…${RESET}"
            echo ""
            local custom_path
            read -rp "Informe o caminho do seu projeto (enter = cancelar): " custom_path
            custom_path="${custom_path/#\~/$HOME}"  # expande ~
            if [[ -z "$custom_path" ]]; then
                return 1
            fi
            if [[ ! -d "$custom_path/.git" ]]; then
                echo -e "${RED}Não é um repo git: ${custom_path}${RESET}"
                return 1
            fi
            local abs_path
            abs_path=$(cd "$custom_path" && pwd)
            repo_register "$abs_path"
            cd "$abs_path" || return 1
            echo -e "${GREEN}→ ${abs_path}${RESET}"
            return 0
        fi

        echo -e "${BOLD}${CYAN}📦 Escolha o projeto:${RESET}"
        echo ""
        local i
        for i in "${!repos[@]}"; do
            local repo="${repos[$i]}"
            local name branch
            name=$(_repo_display_name "$(basename "$repo")")
            branch=$(git -C "$repo" symbolic-ref --short HEAD 2>/dev/null || echo "?")
            printf "  ${BOLD}%2d)${RESET} %-22s ${DIM}[%s] %s${RESET}\n" "$((i+1))" "$name" "$branch" "$repo"
        done
        echo ""
        echo -e "  ${DIM} s) Escanear ${HOME} por mais repos${RESET}"
        echo -e "  ${DIM} 0) Cancelar${RESET}"
        echo ""

        local choice
        read -rp "Escolha [1-${#repos[@]}/s/0]: " choice
        choice=$(normalize_choice "$choice")

        case "$choice" in
            s|S)
                echo -e "${DIM}Escaneando...${RESET}"
                local -a scanned=()
                while IFS= read -r line; do
                    scanned+=("$line")
                done < <(repo_scan)
                if (( ${#scanned[@]} > 0 )); then
                    repo_register "${scanned[@]}"
                fi
                echo -e "${GREEN}✔ ${#scanned[@]} repo(s) indexados.${RESET}"
                echo ""
                continue
                ;;
            0|"")
                return 1
                ;;
        esac

        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#repos[@]} )); then
            local picked="${repos[$((choice-1))]}"
            if ! cd "$picked"; then
                echo -e "${RED}Erro ao entrar em ${picked}.${RESET}"
                return 1
            fi
            repo_register "$picked"
            echo -e "${GREEN}→ ${picked}${RESET}"
            return 0
        fi

        echo -e "${RED}Opção inválida.${RESET}"
        echo ""
    done
}

enter_repo_if_needed() {
    # Pula se --continue/--resume (volta à sessão existente no cwd atual)
    if [[ "$_is_continuing" == true ]]; then
        return
    fi
    if git rev-parse --is-inside-work-tree &>/dev/null; then
        # Registra o repo atual para o picker lembrar em futuras invocações
        repo_register_current
