#!/usr/bin/env bash
# ai - Lançador rápido de CLIs de IA com flags pré-configuradas
# https://github.com/cleofasvolarehost/ai-launcher
#
# Uso: ai (interativo) | ai c/x/g (direto) | ai c "prompt aqui"

# Bash 4+ é necessário (declare -A). macOS vem com bash 3.2.
# Se detectar versão antiga, tenta re-exec com bash do Homebrew.
if (( BASH_VERSINFO[0] < 4 )); then
    for _new_bash in /opt/homebrew/bin/bash /usr/local/bin/bash /opt/local/bin/bash; do
        if [[ -x "$_new_bash" ]] && "$_new_bash" -c '(( BASH_VERSINFO[0] >= 4 ))' 2>/dev/null; then
            exec "$_new_bash" "$0" "$@"
        fi
    done
    echo "Erro: bash 4+ é necessário mas apenas bash ${BASH_VERSION} foi encontrado." >&2
    echo "  Instale via: brew install bash" >&2
    exit 1
fi

set -euo pipefail

AI_LAUNCHER_VERSION="1.3.0"

