# ── Worktree: funções ──────────────────────────────────

wt_get_repo_root() {
    git rev-parse --show-toplevel 2>/dev/null
}

wt_get_repo_name() {
    local root
    root=$(wt_get_repo_root) || return 1
    basename "$root"
}

wt_ensure_git() {
    if ! git rev-parse --is-inside-work-tree &>/dev/null; then
        echo -e "${RED}Erro: não estamos dentro de um repositório git.${RESET}"
        echo -e "${DIM}Navegue até um repo antes de usar worktrees.${RESET}"
        exit 1
    fi
}

wt_base_dir() {
    local repo_name
    repo_name=$(wt_get_repo_name)
    echo "${WORKTREE_BASE}/${repo_name}"
}

wt_list() {
    wt_ensure_git
    local repo_root
    repo_root=$(wt_get_repo_root)

    echo -e "${BOLD}${CYAN}"
    echo "  ┌──────────────────────────────────────────────────┐"
    echo "  │         🌳 Worktrees Ativos                      │"
    echo "  └──────────────────────────────────────────────────┘"
    echo -e "${RESET}"

    local count=0
    local wt_path="" wt_branch=""
    while IFS= read -r line; do
        # Porcelain format: "worktree <path>", "branch refs/heads/<name>", blank line
        if [[ "$line" == "worktree "* ]]; then
            wt_path="${line#worktree }"
        elif [[ "$line" == "branch "* ]]; then
            wt_branch="${line#branch refs/heads/}"
        elif [[ -z "$line" && -n "$wt_path" ]]; then
            # Bloco completo — processa
            if [[ "$wt_path" == "$repo_root" ]]; then
                printf "  ${DIM}principal${RESET}  %-25s %s\n" "$wt_branch" "${DIM}${wt_path}${RESET}"
            else
                count=$((count + 1))

                local status_label
                if git -C "$wt_path" diff --quiet HEAD 2>/dev/null && \
                   git -C "$wt_path" diff --cached --quiet HEAD 2>/dev/null; then
                    status_label="${GREEN}limpo${RESET}"
                else
                    status_label="${YELLOW}modificado${RESET}"
                fi

                local last_commit
                last_commit=$(git -C "$wt_path" log -1 --format='%cr - %s' 2>/dev/null | cut -c1-50)

                printf "  ${BOLD}%d)${RESET} %-22s %b  ${DIM}%s${RESET}\n" "$count" "$wt_branch" "$status_label" "$last_commit"
                printf "     ${DIM}%s${RESET}\n" "$wt_path"
            fi
            wt_path="" wt_branch=""
        fi
    done < <(git worktree list --porcelain 2>/dev/null; echo "")

    if [[ $count -eq 0 ]]; then
        echo -e "  ${DIM}Nenhum worktree extra ativo.${RESET}"
    fi
    echo ""
}

# Variável global para comunicar o nome do worktree criado
_WT_CREATED_NAME=""

wt_new() {
    wt_ensure_git
    local name="$1"
    local base_dir
    base_dir=$(wt_base_dir)
    _WT_CREATED_NAME=""

    if [[ -z "$name" ]]; then
        echo -e "${BOLD}${CYAN}🌳 Novo Worktree${RESET}"
        echo ""
        local sugestao
        sugestao=$(gerar_nome_aleatorio)
        read -rp "$(echo -e "  Nome ${DIM}(enter = ${sugestao})${RESET}: ")" name
        if [[ -z "$name" ]]; then
            name="$sugestao"
        fi
    fi

    # Sanitiza o nome: lowercase, troca espaço por hífen, remove caracteres especiais
    name=$(echo "$name" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | sed 's/[^a-z0-9_-]//g')

    if [[ -z "$name" ]]; then
        echo -e "${RED}Erro: nome inválido.${RESET}"
        return 1
    fi

    local wt_path="${base_dir}/${name}"

    if [[ -d "$wt_path" ]]; then
        echo -e "${RED}Erro: worktree '${name}' já existe em ${wt_path}${RESET}"
        return 1
    fi

    mkdir -p "$base_dir"

    # Verifica se a branch já existe
    if git show-ref --verify --quiet "refs/heads/${name}"; then
        echo -e "${YELLOW}Branch '${name}' já existe, usando ela.${RESET}"
        if ! git worktree add "$wt_path" "$name"; then
            echo -e "${RED}Erro ao criar worktree.${RESET}"
            return 1
        fi
    else
        if ! git worktree add -b "$name" "$wt_path"; then
            echo -e "${RED}Erro ao criar worktree.${RESET}"
            return 1
        fi
    fi

    _WT_CREATED_NAME="$name"

    echo ""
    echo -e "${GREEN}✔ Worktree criado com sucesso!${RESET}"
    echo -e "  ${BOLD}Nome:${RESET}   ${name}"
    echo -e "  ${BOLD}Branch:${RESET} ${name}"
    echo -e "  ${BOLD}Path:${RESET}   ${wt_path}"
    echo ""
    echo -e "  ${DIM}Para entrar:${RESET}  cd ${wt_path}"
    echo -e "  ${DIM}Com Claude:${RESET}   cd ${wt_path} && ai c"

    save_history "worktree:new:${name}"
}

wt_delete() {
    wt_ensure_git
    local name="$1"

    if [[ -z "$name" ]]; then
        # Modo interativo: lista e pede pra escolher
        wt_list

        local repo_root wt_names=()
        repo_root=$(wt_get_repo_root)

        local _p="" _b=""
        while IFS= read -r line; do
            if [[ "$line" == "worktree "* ]]; then
                _p="${line#worktree }"
            elif [[ "$line" == "branch "* ]]; then
                _b="${line#branch refs/heads/}"
            elif [[ -z "$line" && -n "$_p" ]]; then
                [[ "$_p" != "$repo_root" ]] && wt_names+=("$_b")
                _p="" _b=""
            fi
        done < <(git worktree list --porcelain 2>/dev/null; echo "")

        if [[ ${#wt_names[@]} -eq 0 ]]; then
            echo -e "${DIM}Nada pra remover.${RESET}"
            return
        fi

        read -rp "$(echo -e "  ${RED}Número do worktree pra remover (0=cancelar):${RESET} ")" choice
        choice=$(normalize_choice "$choice")
        [[ "$choice" == "0" || -z "$choice" ]] && return

        if [[ "$choice" -ge 1 && "$choice" -le ${#wt_names[@]} ]] 2>/dev/null; then
            name="${wt_names[$((choice - 1))]}"
        else
            echo -e "${RED}Opção inválida.${RESET}"
            return
        fi
    fi

    local base_dir
    base_dir=$(wt_base_dir)
    local wt_path="${base_dir}/${name}"

    # Verifica se o worktree tem mudanças não commitadas
    if [[ -d "$wt_path" ]]; then
        if ! git -C "$wt_path" diff --quiet HEAD 2>/dev/null || \
           ! git -C "$wt_path" diff --cached --quiet HEAD 2>/dev/null; then
            echo -e "${YELLOW}⚠ Worktree '${name}' tem mudanças não commitadas!${RESET}"
            read -rp "$(echo -e "  ${RED}Remover mesmo assim? (s/N):${RESET} ")" confirm
            [[ "$confirm" != "s" && "$confirm" != "S" ]] && return
        fi
    fi

    if git worktree remove "$wt_path" --force 2>/dev/null; then
        # Remove a branch local se não tem tracking remoto
        if ! git show-ref --verify --quiet "refs/remotes/origin/${name}" 2>/dev/null; then
            git branch -D "$name" 2>/dev/null
        fi

        echo -e "${GREEN}✔ Worktree '${name}' removido.${RESET}"
        save_history "worktree:del:${name}"
    else
        echo -e "${RED}Erro ao remover worktree '${name}'.${RESET}"
    fi
}

wt_clean() {
    wt_ensure_git
    echo -e "${BOLD}${CYAN}🧹 Limpando worktrees órfãos...${RESET}"
    echo ""

    # Prune worktrees que apontam pra diretórios deletados
    git worktree prune

    local repo_root removed=0
    repo_root=$(wt_get_repo_root)

    local _p="" _b=""
    while IFS= read -r line; do
        if [[ "$line" == "worktree "* ]]; then
            _p="${line#worktree }"
        elif [[ "$line" == "branch "* ]]; then
            _b="${line#branch refs/heads/}"
        elif [[ -z "$line" && -n "$_p" ]]; then
            if [[ "$_p" != "$repo_root" ]]; then
                local tracking
                tracking=$(git for-each-ref --format='%(upstream:track)' "refs/heads/${_b}" 2>/dev/null)
                if [[ "$tracking" == "[gone]" ]]; then
                    echo -e "  ${YELLOW}Removendo:${RESET} ${_b} ${DIM}(branch remota deletada)${RESET}"
                    git worktree remove "$_p" --force 2>/dev/null
                    git branch -D "$_b" 2>/dev/null
                    removed=$((removed + 1))
                fi
            fi
            _p="" _b=""
        fi
    done < <(git worktree list --porcelain 2>/dev/null; echo "")

    if [[ $removed -eq 0 ]]; then
        echo -e "  ${GREEN}Tudo limpo, nenhum órfão encontrado.${RESET}"
    else
        echo -e "  ${GREEN}✔ ${removed} worktree(s) removido(s).${RESET}"
    fi
    save_history "worktree:clean"
}

wt_open() {
    wt_ensure_git
    local name="$1"

    local base_dir
    base_dir=$(wt_base_dir)

    if [[ -z "$name" ]]; then
        wt_new ""
        name="$_WT_CREATED_NAME"
    fi

    if [[ -z "$name" ]]; then
        return 1
    fi

    local wt_path="${base_dir}/${name}"

    if [[ ! -d "$wt_path" ]]; then
        wt_new "$name"
        name="$_WT_CREATED_NAME"
    fi

    wt_path="${base_dir}/${name}"
    if [[ ! -d "$wt_path" ]]; then
        echo -e "${RED}Erro: worktree não foi criado.${RESET}"
        return 1
    fi

    echo -e "${GREEN}Abrindo Claude em ${wt_path}...${RESET}"
    save_history "worktree:open:${name}"
    cd "$wt_path" && exec claude "${CLAUDE_FLAGS[@]}" --name "${name}"
}

# Cria worktree e faz cd pra ele. Usado por qualquer CLI com -w.
# Seta _WT_DIR com o path para o caller fazer cd.
_WT_DIR=""

wt_prepare() {
    local wt_name="$1"

    wt_ensure_git

    local base_dir
    base_dir=$(wt_base_dir)

    if [[ -z "$wt_name" ]]; then
        wt_new ""
        wt_name="$_WT_CREATED_NAME"
    else
        local wt_path="${base_dir}/${wt_name}"
        if [[ -d "$wt_path" ]]; then
            # Worktree já existe — reutiliza
            echo -e "${DIM}Usando worktree existente: ${wt_name}${RESET}"
        else
            wt_new "$wt_name"
            wt_name="$_WT_CREATED_NAME"
        fi
    fi

    if [[ -z "$wt_name" ]]; then
        return 1
    fi

    _WT_DIR="${base_dir}/${wt_name}"
    _WT_CREATED_NAME="$wt_name"
}

wt_menu() {
    wt_ensure_git
    local repo_name
    repo_name=$(wt_get_repo_name)

    echo -e "${BOLD}${CYAN}"
    echo "  ┌──────────────────────────────────────────────────┐"
    echo "  │         🌳 Worktree Manager                      │"
    echo "  │         repo: ${repo_name}"
    echo "  └──────────────────────────────────────────────────┘"
    echo -e "${RESET}"

    # Conta worktrees existentes
    local repo_root wt_count=0
    repo_root=$(wt_get_repo_root)
    local _p=""
    while IFS= read -r line; do
        if [[ "$line" == "worktree "* ]]; then
            _p="${line#worktree }"
        elif [[ -z "$line" && -n "$_p" ]]; then
            [[ "$_p" != "$repo_root" ]] && wt_count=$((wt_count + 1))
            _p=""
        fi
    done < <(git worktree list --porcelain 2>/dev/null; echo "")

    echo -e "  ${BOLD}1)${RESET} Criar novo worktree"
    echo -e "  ${BOLD}2)${RESET} Listar worktrees ${DIM}(${wt_count} ativos)${RESET}"
    echo -e "  ${BOLD}3)${RESET} Remover worktree"
    echo -e "  ${BOLD}4)${RESET} Limpar órfãos"
    echo -e "  ${BOLD}5)${RESET} Criar + abrir Claude"
    echo -e "  ${DIM}0) Voltar${RESET}"
    echo ""

    read -rp "Escolha [1-5/0]: " choice
    choice=$(normalize_choice "$choice")

    case $choice in
        1) wt_new "" ;;
        2) wt_list ;;
        3) wt_delete "" ;;
        4) wt_clean ;;
        5) wt_open "" ;;
        0) return ;;
        *) echo -e "${RED}Opção inválida.${RESET}" ;;
    esac
}

